    "storage.error.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Storage unavailable" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ストレージを利用できません" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "스토리지를 사용할 수 없음" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "存储不可用" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "儲存空間無法使用" } }
      }
    },
    "storage.error.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "We couldn't open your conversation store. This may be due to storage corruption, a failed migration, or insufficient disk space." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "会話ストアを開けませんでした。ストレージの破損、マイグレーションの失敗、ディスク容量不足などが原因かもしれません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "대화 저장소를 열 수 없습니다. 스토리지 손상, 마이그레이션 실패, 디스크 용량 부족 등이 원인일 수 있습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无法打开会话存储。可能是因为存储损坏、迁移失败或磁盘空间不足。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法開啟對話儲存。可能是儲存損毀、遷移失敗或磁碟空間不足所致。" } }
      }
    },
    "storage.error.resetButton" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset storage" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ストレージをリセット" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "스토리지 초기화" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重置存储" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "重設儲存" } }
      }
    },
    "storage.error.resetConfirmTitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset storage?" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ストレージをリセットしますか?" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "스토리지를 초기화하시겠습니까?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "要重置存储吗?" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "要重設儲存嗎?" } }
      }
    },
    "storage.error.resetConfirmMessage" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "All saved conversations will be deleted. This cannot be undone." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "保存された会話がすべて削除されます。この操作は元に戻せません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "저장된 모든 대화가 삭제됩니다. 되돌릴 수 없습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "所有已保存的对话将被删除。此操作无法撤消。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "所有已儲存的對話將被刪除。此操作無法復原。" } }
      }
    },
    "storage.error.resetConfirm" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset" } },
