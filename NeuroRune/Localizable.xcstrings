        "ko" : { "stringUnit" : { "state" : "translated", "value" : "스토리지가 초기화되었습니다. 앱을 완전히 종료한 후 다시 실행해 주세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "存储已重置。请强制退出应用并重新打开。" } },
