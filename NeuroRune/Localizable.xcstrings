    "onboarding.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You need your own API key to send messages.\nGet one at anthropic.com."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メッセージを送信するにはAPIキーが必要です。\nanthropic.comで取得できます。"
