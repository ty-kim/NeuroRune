        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메시지를 보내려면 본인의 API 키가 필요합니다.\nanthropic.com에서 발급받을 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
